# FeatherCI Configuration
# Copy to .env and fill in your values: cp .env.example .env

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# 32-byte base64 encryption key for secrets
# Generate with: featherci --generate-key
FEATHERCI_SECRET_KEY=

# Public URL (used for OAuth callbacks and webhook URLs)
FEATHERCI_BASE_URL=http://localhost:8080

# Admin usernames (comma-separated, matches OAuth provider username)
# These users can add/remove projects and manage settings
FEATHERCI_ADMINS=yourusername

# =============================================================================
# SERVER SETTINGS
# =============================================================================

# Address to bind the HTTP server
FEATHERCI_BIND_ADDR=:8080

# Database file path (SQLite)
FEATHERCI_DATABASE_PATH=./featherci.db

# Build cache directory
FEATHERCI_CACHE_PATH=./cache

# =============================================================================
# GITHUB OAUTH (Primary)
# =============================================================================
# Create OAuth app at: https://github.com/settings/developers
# Set callback URL to: {FEATHERCI_BASE_URL}/auth/github/callback

FEATHERCI_GITHUB_CLIENT_ID=
FEATHERCI_GITHUB_CLIENT_SECRET=

# =============================================================================
# GITLAB OAUTH (Optional)
# =============================================================================
# Create OAuth app in GitLab settings
# Set callback URL to: {FEATHERCI_BASE_URL}/auth/gitlab/callback

# FEATHERCI_GITLAB_URL=https://gitlab.com
# FEATHERCI_GITLAB_CLIENT_ID=
# FEATHERCI_GITLAB_CLIENT_SECRET=

# =============================================================================
# GITEA/FORGEJO OAUTH (Optional)
# =============================================================================
# Create OAuth app in Gitea/Forgejo settings
# Set callback URL to: {FEATHERCI_BASE_URL}/auth/gitea/callback

# FEATHERCI_GITEA_URL=https://your-gitea.com
# FEATHERCI_GITEA_CLIENT_ID=
# FEATHERCI_GITEA_CLIENT_SECRET=

# =============================================================================
# WORKER CONFIGURATION (Optional)
# =============================================================================
# Mode: "standalone" (default), "master", or "worker"
# - standalone: Single instance acts as both master and worker
# - master: Accepts webhooks and distributes work, no local execution
# - worker: Polls master for jobs, executes builds

# FEATHERCI_MODE=standalone

# Shared secret for worker authentication (required for master/worker mode)
# Generate with: featherci --generate-key
# FEATHERCI_WORKER_SECRET=

# Master URL (required for worker mode)
# FEATHERCI_MASTER_URL=http://master:8080

# =============================================================================
# NOTIFICATIONS
# =============================================================================
# Notifications are configured per-project in the UI (Settings > Notifications).
# Supported channel types: Email (SMTP, SendGrid, Mailgun), Slack, Discord, Pushover.
# No environment variables needed — all settings are stored encrypted in the database.
